<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Favourites Component"
    sling:resourceType="cq/gui/components/authoring/dialog"
    extraClientlibs="[cq.authoring.dialog,srp.authoring]">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs"
                maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">
                    <labels
                        jcr:primaryType="nt:unstructured"
                        jcr:title="SRP Labels"
                        sling:resourceType="granite/ui/components/foundation/include"
                        margin="{Boolean}true"
                        path="/apps/srp/components/common-dialog-fields/labels"/>
                    <links
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Links"
                        sling:resourceType="granite/ui/components/coral/foundation/container"
                        margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <columns
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns"
                                margin="{Boolean}true">
                                <items jcr:primaryType="nt:unstructured">
                                    <column
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/container">
                                        <items jcr:primaryType="nt:unstructured">
                                            <links
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                                                composite="{Boolean}true"
                                                fieldLabel="Favourite Links">
                                                <field
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="granite/ui/components/coral/foundation/container"
                                                    name="./widgetLinks"
                                                    validation="multi-validate">
                                                    <items jcr:primaryType="nt:unstructured">
                                                        <type
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/foundation/form/select"
                                                            class="cq-dialog-dropdown-showhide-multi"
                                                            cq-dialog-dropdown-showhide-target=".test-options-showhide-target"
                                                            fieldLabel="Type"
                                                            name="./type">
                                                            <items jcr:primaryType="nt:unstructured">
                                                                <option1
                                                                    jcr:primaryType="nt:unstructured"
                                                                    text="Document Links Variation"
                                                                    value="docLink"/>
                                                                <option2
                                                                    jcr:primaryType="nt:unstructured"
                                                                    text="Web Links Variation"
                                                                    value="webLink"/>
                                                            </items>
                                                        </type>
                                                        <label
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                            fieldLabel="Enter Label"
                                                            name="./label"/>
                                                        <targetTab
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                            fieldLabel="Select the Target Tab"
                                                            name="./linkType">
                                                            <items jcr:primaryType="nt:unstructured">
                                                                <newtab
                                                                    jcr:primaryType="nt:unstructured"
                                                                    text="New Tab"
                                                                    value="newtab"/>
                                                            </items>
                                                        </targetTab>
                                                        <category
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                            fieldLabel="Select Category"
                                                            name="./category">
                                                            <datasource
                                                                jcr:primaryType="nt:unstructured"
                                                                sling:resourceType="acs-commons/components/utilities/genericlist/datasource"
                                                                path="/etc/acs-commons/lists/srp/link-category"/>
                                                        </category>
                                                        <option1group
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/foundation/container"
                                                            class="hide test-options-showhide-target"
                                                            showhidetargetvalue="docLink">
                                                            <items jcr:primaryType="nt:unstructured">
                                                                <heading
                                                                    jcr:primaryType="nt:unstructured"
                                                                    sling:resourceType="granite/ui/components/foundation/heading"
                                                                    class="coral-Heading coral-Heading--4"
                                                                    level="{Long}4"
                                                                    text="Document Items"/>
                                                                <well
                                                                    jcr:primaryType="nt:unstructured"
                                                                    sling:resourceType="granite/ui/components/foundation/container">
                                                                    <layout
                                                                        jcr:primaryType="nt:unstructured"
                                                                        sling:resourceType="granite/ui/components/foundation/layouts/well"/>
                                                                    <items jcr:primaryType="nt:unstructured">
                                                                        <document
                                                                            jcr:primaryType="nt:unstructured"
                                                                            sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                                                            fieldLabel="Select Document"
                                                                            name="./document"
                                                                            rootPath="/content/dam/srp"/>
                                                                    </items>
                                                                </well>
                                                            </items>
                                                        </option1group>
                                                        <option2group
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/foundation/container"
                                                            class="hide test-options-showhide-target"
                                                            showhidetargetvalue="webLink">
                                                            <items jcr:primaryType="nt:unstructured">
                                                                <heading
                                                                    jcr:primaryType="nt:unstructured"
                                                                    sling:resourceType="granite/ui/components/foundation/heading"
                                                                    class="coral-Heading coral-Heading--4"
                                                                    level="{Long}4"
                                                                    text="Web Items"/>
                                                                <well
                                                                    jcr:primaryType="nt:unstructured"
                                                                    sling:resourceType="granite/ui/components/foundation/container">
                                                                    <layout
                                                                        jcr:primaryType="nt:unstructured"
                                                                        sling:resourceType="granite/ui/components/foundation/layouts/well"/>
                                                                    <items jcr:primaryType="nt:unstructured">
                                                                        <link
                                                                            jcr:primaryType="nt:unstructured"
                                                                            sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                                                            fieldLabel="Select Link Path"
                                                                            name="./webLink"
                                                                            rootPath="/content/srp"/>
                                                                    </items>
                                                                </well>
                                                            </items>
                                                        </option2group>
                                                    </items>
                                                </field>
                                            </links>
                                        </items>
                                    </column>
                                </items>
                            </columns>
                        </items>
                    </links>
                    <tags
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/foundation/include"
                        margin="{Boolean}true"
                        path="/apps/srp/components/common-dialog-fields/tags"/>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
