<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Header"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs"
                maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">
                    <properties
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Properties"
                        sling:resourceType="granite/ui/components/coral/foundation/container"
                        margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <columns
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns"
                                margin="{Boolean}true">
                                <items jcr:primaryType="nt:unstructured">
                                    <column
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/container">
                                        <items jcr:primaryType="nt:unstructured">
                                            <desktopBlueLogo
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                                fieldLabel="Select Desktop Blue Logo"
                                                name="./desktopBlueLogo"
                                                required="{Boolean}false"
                                                rootPath="/content/dam/srp"/>
                                            <desktopCatalogLogo
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                                fieldLabel="Select Desktop Catalog Logo"
                                                name="./desktopCatalogLogo"
                                                required="{Boolean}false"
                                                rootPath="/content/dam/srp"/>
                                            <showNotificationIcon
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                                name="./showNotificationIcon"
                                                text="Show Notification Icon"
                                                uncheckedValue="{Boolean}false"
                                                value="{Boolean}true"/>
                                            <desktopBlueLogoAlt
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                fieldLabel="Enter Desktop Blue Logo Alt Src"
                                                name="./desktopBlueLogoAlt"
                                                required="{Boolean}true"/>
                                            <desktopCatalogLogoAlt
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                fieldLabel="Enter Desktop Catalog Logo Alt Src"
                                                name="./desktopCatalogLogoAlt"
                                                required="{Boolean}true"/>
                                            <desktopErcsBlueLogo
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                                fieldLabel="Select Desktop Ercs Blue Logo"
                                                name="./desktopErcsBlueLogo"
                                                required="{Boolean}false"
                                                rootPath="/content/dam/srp"/>
                                            <desktopErcsCatalogLogo
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                                fieldLabel="Select Desktop Ercs Catalog Logo"
                                                name="./desktopErcsCatalogLogo"
                                                required="{Boolean}false"
                                                rootPath="/content/dam/srp"/>
                                            <desktopErcsBlueLogoAlt
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                fieldLabel="Enter Desktop Ercs Blue Logo Alt Src"
                                                name="./desktopErcsBlueLogoAlt"
                                                required="{Boolean}true"/>
                                            <desktopErcsCatalogLogoAlt
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                fieldLabel="Enter Ercs Desktop Catalog Logo Alt Src"
                                                name="./desktopErcsCatalogLogoAlt"
                                                required="{Boolean}true"/>
                                        </items>
                                    </column>
                                </items>
                            </columns>
                        </items>
                    </properties>
                    <application-logos
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Application Logos"
                        sling:resourceType="granite/ui/components/coral/foundation/container"
                        margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <columns
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns"
                                margin="{Boolean}true">
                                <items jcr:primaryType="nt:unstructured">
                                    <column
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/container">
                                        <items jcr:primaryType="nt:unstructured">
                                            <ApplicationLinks
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                                                composite="{Boolean}true"
                                                fieldLabel="Application Links">
                                                <field
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="granite/ui/components/coral/foundation/container"
                                                    name="./ApplicationLinks"
                                                    validation="multi-validate">
                                                    <items jcr:primaryType="nt:unstructured">
                                                        <app-category
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                            fieldLabel="Select Application Category"
                                                            name="./appcategory"
                                                            required="{Boolean}true">
                                                            <datasource
                                                                jcr:primaryType="nt:unstructured"
                                                                sling:resourceType="acs-commons/components/utilities/genericlist/datasource"
                                                                path="/etc/acs-commons/lists/srp/srp-application-category"/>
                                                        </app-category>
                                                        <name
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                            fieldLabel="Enter Application Name"
                                                            name="./name"
                                                            required="{Boolean}true"/>
                                                        <link
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                                            fieldLabel="Enter Application Url"
                                                            name="./link"
                                                            required="{Boolean}true"
                                                            rootPath="/content"/>
                                                        <icon
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                                            fieldLabel="Select Respective Application icon"
                                                            name="./icon"
                                                            required="{Boolean}false"
                                                            rootPath="/content/dam/srp"/>
                                                    </items>
                                                </field>
                                            </ApplicationLinks>
                                        </items>
                                    </column>
                                </items>
                            </columns>
                        </items>
                    </application-logos>
                    <labels
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/foundation/include"
                        margin="{Boolean}true"
                        path="/apps/srp/components/common-dialog-fields/labels"/>
                    <tags
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/foundation/include"
                        margin="{Boolean}true"
                        path="/apps/srp/components/common-dialog-fields/tags"/>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
