<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Catalog"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs"
                maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">
                    <labels
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/foundation/include"
                        margin="{Boolean}true"
                        path="/apps/srp/components/common-dialog-fields/labels"/>
                    <categories
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Categories"
                        sling:resourceType="granite/ui/components/coral/foundation/container"
                        margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <columns
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns"
                                margin="{Boolean}true">
                                <items jcr:primaryType="nt:unstructured">
                                    <column
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/container">
                                        <items jcr:primaryType="nt:unstructured">
                                            <cataegories
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                                                composite="{Boolean}true"
                                                fieldLabel="Categories">
                                                <field
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="granite/ui/components/coral/foundation/container"
                                                    name="./categories"
                                                    validation="multi-validate">
                                                    <items jcr:primaryType="nt:unstructured">
                                                        <category-id
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                            fieldLabel="Select Category ID"
                                                            name="./categoryId">
                                                            <datasource
                                                                jcr:primaryType="nt:unstructured"
                                                                sling:resourceType="acs-commons/components/utilities/genericlist/datasource"
                                                                path="/etc/acs-commons/lists/srp/srp-application-category"/>
                                                        </category-id>
                                                        <category-label
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                            fieldLabel="Enter Catalog Label"
                                                            name="./categoryLabel"/>
                                                    </items>
                                                </field>
                                            </cataegories>
                                        </items>
                                    </column>
                                </items>
                            </columns>
                        </items>
                    </categories>
                    <catalogs
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Catalogs"
                        sling:resourceType="granite/ui/components/coral/foundation/container"
                        margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <columns
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns"
                                margin="{Boolean}true">
                                <items jcr:primaryType="nt:unstructured">
                                    <column
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/container">
                                        <items jcr:primaryType="nt:unstructured">
                                            <catalog
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                                                composite="{Boolean}true"
                                                fieldLabel="Catalog">
                                                <field
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="granite/ui/components/coral/foundation/container"
                                                    name="./catalogs"
                                                    validation="multi-validate">
                                                    <items jcr:primaryType="nt:unstructured">
                                                        <label
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                            fieldLabel="Enter Label"
                                                            name="./label"/>
                                                        <category
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                            fieldLabel="Select Category"
                                                            name="./category">
                                                            <datasource
                                                                jcr:primaryType="nt:unstructured"
                                                                sling:resourceType="acs-commons/components/utilities/genericlist/datasource"
                                                                path="/etc/acs-commons/lists/srp/link-category"/>
                                                        </category>
                                                        <link
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                                            fieldLabel="Enter Application Url"
                                                            name="./link"
                                                            rootPath="/content"/>
                                                        <linkType
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                            fieldLabel="Select the Link Type"
                                                            name="./linkType">
                                                            <items jcr:primaryType="nt:unstructured">
                                                                <default
                                                                    jcr:primaryType="nt:unstructured"
                                                                    text="Default Tab"
                                                                    value="default"/>
                                                                <newtab
                                                                    jcr:primaryType="nt:unstructured"
                                                                    text="New Tab"
                                                                    value="newtab"/>
                                                            </items>
                                                        </linkType>
                                                        <icon
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                                            fieldLabel="Select Respective Application icon"
                                                            name="./icon"
                                                            required="{Boolean}false"
                                                            rootPath="/content/dam/srp"/>
                                                        <catalog-id
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                            fieldLabel="Select Catalog ID"
                                                            name="./catalogId">
                                                            <datasource
                                                                jcr:primaryType="nt:unstructured"
                                                                sling:resourceType="acs-commons/components/utilities/genericlist/datasource"
                                                                path="/etc/acs-commons/lists/srp/srp-application-catalog"/>
                                                        </catalog-id>
                                                        <category-id
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                            fieldLabel="Select Category ID"
                                                            name="./categoryId">
                                                            <datasource
                                                                jcr:primaryType="nt:unstructured"
                                                                sling:resourceType="acs-commons/components/utilities/genericlist/datasource"
                                                                path="/etc/acs-commons/lists/srp/srp-application-category"/>
                                                        </category-id>
                                                        <authField
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                            fieldLabel="Select Auth Type"
                                                            name="./authField"
                                                            required="{Boolean}false">
                                                            <datasource
                                                                jcr:primaryType="nt:unstructured"
                                                                sling:resourceType="acs-commons/components/utilities/genericlist/datasource"
                                                                path="/etc/acs-commons/lists/srp/auth-type"/>
                                                        </authField>
                                                    </items>
                                                </field>
                                            </catalog>
                                        </items>
                                    </column>
                                </items>
                            </columns>
                        </items>
                    </catalogs>
                    <tags
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/foundation/include"
                        margin="{Boolean}true"
                        path="/apps/srp/components/common-dialog-fields/tags"/>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
